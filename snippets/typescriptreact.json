{
  "useState": {
    "prefix": "usf",
    "body": "const [${1:state}, set${1/(.*)/${1:/capitalize}/}] = useState($2)",
    "description": "useState hook"
  },
  "useEffect": {
    "prefix": "ue",
    "body": "useEffect(() => {\n\t$0\n}, [$1])",
    "description": "useEffect hook"
  },
  "useEffect empty deps": {
    "prefix": "uef",
    "body": "useEffect(() => {\n\t$0\n}, [])",
    "description": "useEffect hook with empty dependency array"
  },
  "useRef": {
    "prefix": "ur",
    "body": "const $1 = useRef($2)",
    "description": "useRef hook"
  },
  "useMemo": {
    "prefix": "um",
    "body": "const $1 = useMemo(() => $2, [$3])",
    "description": "useMemo hook"
  },
  "useCallback": {
    "prefix": "ucb",
    "body": "const $1 = useCallback(() => {\n\t$0\n}, [$2])",
    "description": "useCallback hook"
  },
  "className": {
    "prefix": "cn",
    "body": "className='$1'",
    "description": "className attribute"
  },
  "onClick": {
    "prefix": "oc",
    "body": "onClick={$1}",
    "description": "onClick handler"
  },
  "fragment": {
    "prefix": "frag",
    "body": "<>\n\t$0\n</>",
    "description": "React fragment"
  }
}
