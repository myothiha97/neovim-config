 " Disable speed search in tree views
   set idearefactormode=keep

" ============================================================================
" Quick Reference (matches your muscle memory):
"
" PERSONAL MAPPINGS:
"   <leader>va    - Select all
"   <leader>ya    - Yank all
"   Alt+/         - Toggle comment
"   Tab           - Hover docs (normal mode)
"   Ctrl+I        - Signature help
"   gi            - Line diagnostics
"   ge/gp         - Next/prev error
"   Shift+Arrows  - Resize window
"   <leader>l     - Console.log (visual)
"   <leader>sl    - Find in current file
"   tt/tp         - Next/prev todo
"
" LAZYVIM NAVIGATION:
"   <leader><space> - Find files
"   <leader>ff      - Find files
"   <leader>/       - Grep
"   <leader>sg      - Grep
"   <leader>fb      - Buffers
"   <leader>fr      - Recent files
"   gd              - Go to definition
"   gr              - Find usages
"   gI              - Go to implementation
"   K               - Hover docs
"
" LAZYVIM EDITING:
"   gcc             - Toggle comment line
"   <leader>ca      - Code actions
"   <leader>cr      - Rename
"   <leader>cf      - Format
"   Alt+j/k         - Move lines
"   s/S             - Flash jump (EasyMotion)
"
" TOOL WINDOWS:
"   Ctrl+h          - Project View (left)
"   Ctrl+l          - Editor (center)
"   Ctrl+j          - Terminal (bottom)
"   Ctrl+k          - Editor (from bottom)
"   Shift+h/l       - Prev/next tab
"   <leader>e       - Toggle Project View
"
" LAZYVIM GIT:
"   <leader>gg      - Git panel
"   <leader>gb      - Git blame
"   <leader>gd      - Git diff
"   ]h/[h           - Next/prev hunk
"   <leader>ghs     - Stage hunk
"
" LAZYVIM DEBUG:
"   <leader>db      - Toggle breakpoint
"   <leader>dc      - Continue
"   <leader>di      - Step into
"   <leader>do      - Step out
"   <leader>dO      - Step over
"
" LAZYVIM TEST:
"   <leader>tt      - Run test file
"   <leader>tr      - Run nearest test
"   <leader>ts      - Test summary
" ============================================================================
