" ============================================================================
" LAZYVIM: File Explorer + Neo-tree Style Keybindings
" ============================================================================

" Toggle file explorer (use HideActiveWindow to toggle off)
nmap <leader>e <Action>(SelectInProjectView)
nmap <leader>E <Action>(SelectInProjectView)
nmap <leader>fe <Action>(ActivateProjectToolWindow)
nmap <leader>fE <Action>(SelectInProjectView)

" ============================================================================
" PROJECT VIEW - NERDTree Keybindings
" ============================================================================

" NERDTree mappings (these ONLY work in Project View, not editor)
let g:NERDTreeMapActivateNode = 'l'
let g:NERDTreeMapOpenSplit = 'i'
let g:NERDTreeMapOpenVSplit = 's'
let g:NERDTreeMapPreview = 'go'
let g:NERDTreeMapCloseDir = 'h'
let g:NERDTreeMapCloseChildren = 'X'
let g:NERDTreeMapJumpParent = 'p'
let g:NERDTreeMapJumpRoot = 'P'
let g:NERDTreeMapRefresh = 'r'
let g:NERDTreeMapRefreshRoot = 'R'
let g:NERDTreeMapMenu = 'a'
let g:NERDTreeMapQuit = 'q'
let g:NERDTreeMapToggleZoom = 'Z'

" Navigation (in Project View):
"   j/k          - Move up/down
"   l or Enter   - Open file / expand folder
"   h            - Collapse folder
"   O            - Recursively open
"   s            - Open in vertical split
"   i            - Open in horizontal split
"   go           - Preview (open without focus)
"   X            - Close all children
"   p            - Go to parent
"   P            - Go to root
"   q            - Close/back to editor
"   r            - Refresh
"   R            - Refresh root
"   Z            - Zoom/maximize
"
" File Operations:
"   a            - Open menu (Add/Delete/Rename/Copy/Move)
"                  Then select: (a)dd, (d)elete, (r)ename, (c)opy, (m)ove
"
" Tool Window Navigation (configure in Keymap settings):
"   Ctrl+h       - Focus Project View (left)
"   Ctrl+l       - Focus Editor (center)
"   Ctrl+j       - Focus Terminal (bottom)
"   Ctrl+k       - Focus Editor (from bottom)

" ============================================================================
" Folding
" ============================================================================

nmap za <Action>(ExpandCollapseToggleAction)
nmap zA <Action>(ExpandCollapseToggleAction)
nmap zc <Action>(CollapseRegion)
nmap zC <Action>(CollapseRegionRecursively)
nmap zo <Action>(ExpandRegion)
nmap zO <Action>(ExpandRegionRecursively)
nmap zM <Action>(CollapseAllRegions)
nmap zR <Action>(ExpandAllRegions)
nmap zm <Action>(CollapseAllRegions)
nmap zr <Action>(ExpandAllRegions)
nmap zj <Action>(NextFoldRegion)
nmap zk <Action>(PreviousFoldRegion)

" ============================================================================
" Additional Convenience Mappings
" ============================================================================

" Better paste in visual mode (don't yank replaced text)
vnoremap p "_dP

" Quick escape alternatives
inoremap jk <Esc>
inoremap jj <Esc>

" Quick save
nmap <leader>w :w<CR>

" Keep IDE handling for certain keys
sethandler <C-n> a:ide
sethandler <C-p> a:ide
sethandler <C-c> a:ide
sethandler <C-v> a:ide
sethandler <C-a> a:ide
sethandler <C-x> a:ide

" Let IDE handle Ctrl+h/j/k/l globally (works from Project View, Terminal, Editor)
sethandler <C-h> a:ide
sethandler <C-j> a:ide
sethandler <C-k> a:ide
sethandler <C-l> a:ide

