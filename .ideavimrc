" ============================================================================
" IdeaVim Configuration - Complete Neovim/LazyVim Keybindings
" Synced from: ~/.config/nvim (personal) + LazyVim defaults
" ============================================================================

" --- Basic Settings (matching Neovim options) ---
set number
set relativenumber
set scrolloff=8
set sidescrolloff=8
set clipboard+=unnamedplus
set ignorecase
set smartcase
set incsearch
set hlsearch
set showmode
set showcmd
set visualbell
set ideajoin
set idearefactormode=keep

" Leader key
let mapleader = " "

" --- IdeaVim Plugins ---
set surround          " ys, cs, ds commands (vim-surround)
set commentary        " gcc, gc commands (vim-commentary)
set highlightedyank   " Brief highlight on yank
set easymotion        " <leader><leader> motions
set NERDTree          " j/k navigation in Project View
set multiple-cursors  " Multi-cursor support
set argtextobj        " aa, ia for function arguments
set textobj-entire    " ae, ie for entire file
set matchit           " Extended % matching
set exchange          " cx, cxx for exchange
set ReplaceWithRegister " gr to replace with register

" Which-key support (shows keybinding hints)
set which-key
set notimeout
let g:WhichKey_ShowVimActions = "true"

" ============================================================================
" PERSONAL CONFIG: lua/config/keymaps.lua
" ============================================================================

" --- Select/Yank All ---
nnoremap <leader>va ggVG
nnoremap <leader>ya ggyG

" --- Comment Toggle (Alt+/) ---
nmap <A-/> gcc
vmap <A-/> gc

" --- Scroll and Recenter ---
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz
nnoremap <C-f> <C-f>zz
nnoremap <C-b> <C-b>zz
vnoremap <C-d> <C-d>zz
vnoremap <C-u> <C-u>zz
vnoremap <C-f> <C-f>zz
vnoremap <C-b> <C-b>zz

" --- Hover Documentation (Tab in normal mode) ---
nmap <Tab> <Action>(QuickJavaDoc)

" --- Signature Help (Ctrl+I) ---
imap <C-i> <Action>(ParameterInfo)
nmap <C-i> <Action>(ParameterInfo)

" --- Line Diagnostics (gi) ---
nmap gi <Action>(ShowErrorDescription)

" --- Navigate Errors (ge/gp - your personal mappings) ---
nmap ge <Action>(GotoNextError)
nmap gp <Action>(GotoPreviousError)

" --- Window Resize with Shift+Arrow ---
nmap <S-Up> <Action>(StretchSplitToTop)
nmap <S-Down> <Action>(StretchSplitToBottom)
nmap <S-Left> <Action>(StretchSplitToLeft)
nmap <S-Right> <Action>(StretchSplitToRight)

" --- Console Log Helper (visual mode) ---
vmap <leader>l yoconsole.log('<C-r>" -> ', <C-r>");<Esc>

" --- Grep in Current File ---
nmap <leader>sl <Action>(Find)

" --- Todo Navigation (from todo-comments.lua) ---
nmap tt <Action>(FindNext)
nmap tp <Action>(FindPrevious)

" ============================================================================
" LAZYVIM DEFAULTS: Core Keymaps
" ============================================================================

" --- Better j/k movement (wrapped lines) ---
nnoremap j gj
nnoremap k gk
vnoremap j gj
vnoremap k gk

" --- Window Navigation (Ctrl+hjkl) - Tool Windows ---
" Global navigation between tool windows (works from anywhere!)
" Configured in IDE keymap (not IdeaVim) so it works from Project View & Terminal too
" Ctrl+h = Project View (left)
" Ctrl+l = Editor (center)
" Ctrl+j = Terminal (bottom)
" Ctrl+k = Editor (from bottom)
" NOTE: These are handled by IDE keymap, not IdeaVim (see sethandler below)

" --- Window Resize (Ctrl+Arrow) ---
nmap <C-Up> <Action>(StretchSplitToTop)
nmap <C-Down> <Action>(StretchSplitToBottom)
nmap <C-Left> <Action>(StretchSplitToLeft)
nmap <C-Right> <Action>(StretchSplitToRight)

" --- Line Movement (Alt+j/k) ---
nmap <A-j> <Action>(MoveLineDown)
nmap <A-k> <Action>(MoveLineUp)
imap <A-j> <Esc><Action>(MoveLineDown)i
imap <A-k> <Esc><Action>(MoveLineUp)i
vmap <A-j> <Action>(MoveLineDown)
vmap <A-k> <Action>(MoveLineUp)

" --- Buffer/Tab Navigation ---
nmap <S-h> <Action>(PreviousTab)
nmap <S-l> <Action>(NextTab)
nmap [b <Action>(PreviousTab)
nmap ]b <Action>(NextTab)
nmap <leader>bb <Action>(RecentFiles)
nmap <leader>` <Action>(RecentFiles)
nmap <leader>bd <Action>(CloseContent)
nmap <leader>bo <Action>(CloseAllEditorsButActive)
nmap <leader>bD <Action>(CloseContent)
nmap <leader>bp <Action>(PinActiveEditorTab)
nmap <leader>bP <Action>(CloseAllUnpinnedEditors)
nmap <leader>br <Action>(CloseAllToTheRight)
nmap <leader>bl <Action>(CloseAllToTheLeft)

" --- Split Windows ---
nmap <leader>- <Action>(SplitHorizontally)
nmap <leader>\| <Action>(SplitVertically)
nmap <leader>wv <Action>(SplitVertically)
nmap <leader>ws <Action>(SplitHorizontally)
nmap <leader>wd <Action>(Unsplit)
nmap <leader>wc <Action>(Unsplit)
nmap <leader>ww <Action>(NextSplitter)
nmap <leader>wm <Action>(MaximizeEditorInSplit)

" --- Better Indenting (stay in visual mode) ---
vnoremap < <gv
vnoremap > >gv

" --- Add Comment Below/Above ---
nmap gco <Action>(CommentByLineComment)j
nmap gcO k<Action>(CommentByLineComment)

" --- Save File (Ctrl+s) ---
nmap <C-s> :w<CR>
imap <C-s> <Esc>:w<CR>a
vmap <C-s> <Esc>:w<CR>gv

" --- New File ---
nmap <leader>fn <Action>(NewFile)

" --- Escape and Clear Search ---
" Use :noh to clear search, but don't override Esc (breaks multi-cursor exit)
nmap <leader>h :noh<CR>
" Esc handled natively for multi-cursor exit

" --- Diagnostics Navigation ---
nmap <leader>cd <Action>(ShowErrorDescription)
nmap ]d <Action>(GotoNextError)
nmap [d <Action>(GotoPreviousError)
nmap ]e <Action>(GotoNextError)
nmap [e <Action>(GotoPreviousError)
nmap ]w <Action>(GotoNextError)
nmap [w <Action>(GotoPreviousError)

" --- Quickfix/Location List ---
nmap <leader>xl <Action>(ActivateProblemsViewToolWindow)
nmap <leader>xq <Action>(ActivateProblemsViewToolWindow)
nmap [q <Action>(GotoPreviousError)
nmap ]q <Action>(GotoNextError)

" --- Formatting ---
nmap <leader>cf <Action>(ReformatCode)
vmap <leader>cf <Action>(ReformatCode)
nmap <leader>cF <Action>(ReformatCode)

" --- Terminal ---
nmap <C-/> <Action>(ActivateTerminalToolWindow)
nmap <leader>ft <Action>(ActivateTerminalToolWindow)
nmap <leader>fT <Action>(ActivateTerminalToolWindow)

" --- Tabs ---
nmap <leader><tab>l <Action>(GoToLastTab)
nmap <leader><tab>o <Action>(CloseAllEditorsButActive)
nmap <leader><tab>f <Action>(GoToTab1)
nmap <leader><tab><tab> <Action>(NewFile)
nmap <leader><tab>] <Action>(NextTab)
nmap <leader><tab>d <Action>(CloseContent)
nmap <leader><tab>[ <Action>(PreviousTab)

" --- Lazy/Plugin Manager ---
nmap <leader>l <Action>(WelcomeScreen.Plugins)

" --- Quit All ---
nmap <leader>qq <Action>(Exit)

" --- Inspect ---
nmap <leader>ui <Action>(QuickTypeDefinition)
nmap <leader>uI <Action>(ExpressionTypeInfo)

" --- Git (Lazygit style) ---
nmap <leader>gg <Action>(ActivateVersionControlToolWindow)
nmap <leader>gG <Action>(ActivateVersionControlToolWindow)
nmap <leader>gL <Action>(Vcs.ShowTabbedFileHistory)
nmap <leader>gb <Action>(Annotate)
nmap <leader>gf <Action>(Vcs.ShowTabbedFileHistory)
nmap <leader>gl <Action>(Vcs.Show.Log)
nmap <leader>gB <Action>(Git.Branches)
nmap <leader>gc <Action>(CheckinProject)
nmap <leader>gp <Action>(Vcs.Push)

" --- Toggle Options ---
nmap <leader>uf <Action>(ToggleRenderedDocPresentation)
nmap <leader>us <Action>(ToggleSpelling)
nmap <leader>uw <Action>(EditorToggleUseSoftWraps)
nmap <leader>uL <Action>(EditorToggleShowLineNumbers)
nmap <leader>ul <Action>(EditorToggleShowLineNumbers)
nmap <leader>ud <Action>(ToggleDistractionFreeMode)
nmap <leader>uz <Action>(ToggleZenMode)

