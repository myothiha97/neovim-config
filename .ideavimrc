let g:WhichKeyDesc_q = "<leader>q Quit/Session"
let g:WhichKeyDesc_r = "<leader>r Run"
let g:WhichKeyDesc_s = "<leader>s Search"
let g:WhichKeyDesc_t = "<leader>t Test"
let g:WhichKeyDesc_u = "<leader>u UI/Toggle"
